# Optional .env file for secrets you'd rather not put in config.toml.
# Any value here overrides the matching key in config.toml.
# Naming rule: ANIMADEX_<SECTION>_<KEY> (upper-case).
#
# Copy to .env and fill in. .env is gitignored.

# ANIMADEX_ADMIN_PASSWORD=
# ANIMADEX_SERVER_SECRET_KEY=
# ANIMADEX_CIVITAI_API_KEY=
